{
  "manifest_version": 3,
  "name": "KeremOS YouTube Tracker",
  "version": "1.0",
  "description": "YouTube izleme süresini API'ye gönderir",
  "permissions": [],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"]
    }
  ]
}